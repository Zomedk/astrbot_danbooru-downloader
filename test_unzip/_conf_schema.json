{
  "conf_schema": [
    {
      "type": "section",
      "title": "Danbooru API 配置",
      "children": [
        {
          "type": "text",
          "name": "username",
          "label": "Danbooru 用户名",
          "required": true,
          "placeholder": "输入你的Danbooru用户名"
        },
        {
          "type": "password",
          "name": "api_key",
          "label": "API Key",
          "required": true,
          "placeholder": "输入你的Danbooru API Key"
        }
      ]
    },
    {
      "type": "section",
      "title": "下载设置",
      "children": [
        {
          "type": "number",
          "name": "max_workers",
          "label": "并发下载数",
          "default": 10,
          "min": 1,
          "max": 20
        },
        {
          "type": "number",
          "name": "target_count",
          "label": "每个角色下载数量",
          "default": 50,
          "min": 10,
          "max": 200
        }
      ]
    }
  ]
}
